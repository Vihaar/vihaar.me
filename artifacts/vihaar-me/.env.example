# Optional: Stripe Payment Link from Dashboard → Payment Links (e.g. https://buy.stripe.com/...)
VITE_STRIPE_DONATION_URL=

# Publishable key from Stripe Dashboard → Developers → API keys (copy pk_live_… or pk_test_…)
VITE_STRIPE_PUBLISHABLE_KEY=

# API base for Stripe Checkout Session. Leave empty in dev so requests go to /api (Vite proxies to the local api-server).
# In production, set to your API origin (no trailing slash), e.g. https://api.vihaar.me
VITE_API_BASE=

# (Vite config only) Override API proxy target when running `pnpm dev`
# VITE_API_PROXY_TARGET=http://127.0.0.1:<your-api-port>
