PORT=8787

# Copy this file to `.env` in this same folder:
#   artifacts/api-server/.env
# The server loads that file on startup (see src/load-env.ts). If you start the API from the monorepo
# root, fallbacks also check `artifacts/api-server/.env` and `vihaar.me/artifacts/api-server/.env` relative to cwd.

# Stripe SECRET key (Dashboard → Developers → API keys).
# Use sk_test_... for dev, sk_live_... for production — must match the same account as your pk_ key on the site.
STRIPE_SECRET_KEY=sk_test_...

# Where Stripe sends the user after pay / cancel (no trailing slash). Bad URLs here can break session creation.
# Production example: https://vihaar.me — you can omit https:// only if the value is a bare hostname (we prepend https://).
FRONTEND_ORIGIN=http://localhost:5173
